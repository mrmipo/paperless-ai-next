    "axios": "^1.15.2",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.8.1",
    "body-parser": "^1.20.3",
    "chart.js": "^3.7.0",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "datatables.net": "^1.13.7",
    "datatables.net-dt": "^1.13.7",
    "date-fns": "^4.1.0",
    "dockerode": "^5.0.0",
    "dotenv": "^16.4.7",
