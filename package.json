    "rimraf": "^6.0.1",
    "shepherd.js": "^10.0.1",
    "sortablejs": "^1.15.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "sweetalert2": "^11.22.4",
    "tiktoken": "^1.0.20",
    "tippy.js": "^6.3.7"
