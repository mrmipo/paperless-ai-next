<!DOCTYPE html>
<html lang="en" class="h-full<%= theme === 'dark' ? ' dark' : '' %>" data-theme="<%= theme || 'light' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <title>Initial Setup - Paperless-AI next</title>
    <link rel="icon" type="image/webp" href="/favicon.webp">
    <%- include('partials/shell/theme-init-head') %>
    <script src="/vendor/tailwind/tailwindcss-3.4.16.js"></script>
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/darkmode.css">
    <link rel="stylesheet" href="/css/setup.css">
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
</head>
<body class="h-full bg-secondary setup-page">
    <button id="themeToggle" class="theme-toggle" aria-label="Toggle theme">
        <i class="fas fa-moon"></i>
    </button>

    <div class="setup-background" aria-hidden="true">
        <div class="setup-glow setup-glow-a"></div>
        <div class="setup-glow setup-glow-b"></div>
        <div class="setup-grid"></div>
    </div>

    <main class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 py-8">
        <section class="material-card setup-card w-full max-w-4xl" aria-labelledby="setupTitle">
            <header class="text-center mb-8">
                <div class="flex flex-col items-center justify-center gap-3 mb-4">
                    <img src="/favicon.webp" class="no-invert" alt="Paperless AI next Logo" style="height: 60px;">
                    <h1 id="setupTitle" class="brand-title text-2xl">Paperless-AI<span class="text-sm font-semibold text-blue-700"> next</span></h1>
                </div>
                <h2 class="text-2xl font-bold">Initial Installer</h2>
                <p class="setup-subtitle">Complete each step to configure your instance.</p>
                <% if (typeof success === 'string' && success) { %>
                    <p class="setup-notice setup-notice-success mt-4"><%= success %></p>
                <% } %>
                <% if (typeof error === 'string' && error) { %>
                    <p class="setup-notice setup-notice-error mt-4"><%= error %></p>
                <% } %>
            </header>

            <div class="setup-progress-wrap mb-6">
                <div class="setup-progress-bar">
                    <div id="setupProgressFill" class="setup-progress-fill" style="width: 14.2857%;"></div>
                </div>
                <div id="setupStepLabel" class="setup-step-label mt-2">Step 1 of 7: Admin account</div>
            </div>

            <form id="setupWizardForm" class="space-y-6" novalidate>
                <section class="setup-step is-active" data-step-index="0" data-step-title="Admin account">
                    <h3 class="setup-section-title"><i class="fas fa-user-shield"></i> Admin account</h3>
                    <p class="setup-section-help">Create the initial Paperless-AI next administrator account.</p>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                        <div class="space-y-2 md:col-span-2">
                            <label for="adminUsername" class="text-sm font-medium">Username</label>
                            <input id="adminUsername" name="adminUsername" type="text" class="setup-input" required autocomplete="username">
                        </div>
                        <div class="space-y-2">
                            <label for="adminPassword" class="text-sm font-medium">Password</label>
                            <input id="adminPassword" name="adminPassword" type="password" class="setup-input" required autocomplete="new-password" minlength="8">
                            <p id="passwordHint" class="setup-hint">Use at least 8 characters.</p>
                        </div>
                        <div class="space-y-2">
                            <label for="confirmPassword" class="text-sm font-medium">Confirm password</label>
                            <input id="confirmPassword" name="confirmPassword" type="password" class="setup-input" required autocomplete="new-password" minlength="8">
                        </div>
                    </div>
                </section>

                <section class="setup-step" data-step-index="1" data-step-title="MFA setup">
                    <h3 class="setup-section-title"><i class="fas fa-shield-halved"></i> Multi-factor authentication (MFA)</h3>
                    <p class="setup-section-help">Would you like to enable MFA for the admin account?</p>

                    <div class="space-y-2 mt-4">
                        <label for="enableMfa" class="text-sm font-medium">Enable MFA</label>
                        <select id="enableMfa" name="enableMfa" class="setup-input">
                            <option value="no">No</option>
                            <option value="yes">Yes</option>
                        </select>
                    </div>

                    <div id="mfaSetupPanel" class="setup-panel hidden mt-4 space-y-4">
                        <button type="button" id="startMfaSetupBtn" class="setup-btn setup-btn-secondary">
                            <i class="fas fa-qrcode"></i>
                            Generate QR code
                        </button>

                        <div id="mfaProvisioningBox" class="setup-provisioning hidden">
                            <div class="flex flex-col md:flex-row gap-4">
                                <div class="setup-qr-box">
                                    <img id="setupMfaQrImage" class="w-44 h-44 rounded border border-gray-200 bg-white p-2 hidden" alt="MFA setup QR code">
                                </div>
                                <div class="flex-1 space-y-3">
                                    <div class="space-y-2">
                                        <label for="setupMfaSecret" class="text-sm font-medium">Secret key</label>
                                        <input id="setupMfaSecret" type="text" class="setup-input" readonly>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="setupMfaCode" class="text-sm font-medium">Authenticator code</label>
                                        <div class="flex gap-2">
                                            <input id="setupMfaCode" type="text" inputmode="numeric" autocomplete="one-time-code" class="setup-input flex-1" placeholder="Enter 6-digit code">
                                            <button type="button" id="confirmMfaCodeBtn" class="setup-btn setup-btn-secondary">Confirm</button>
                                        </div>
                                        <p id="mfaStatusHint" class="setup-hint"></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="setup-step" data-step-index="2" data-step-title="Paperless connection">
                    <h3 class="setup-section-title"><i class="fas fa-link"></i> Paperless-ngx connection</h3>
                    <p class="setup-section-help">Enter your Paperless-ngx API credentials and run a connectivity test.</p>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                        <div class="space-y-2 md:col-span-2">
                            <label for="paperlessUrl" class="text-sm font-medium">Paperless-ngx API URL</label>
                            <input id="paperlessUrl" name="paperlessUrl" type="text" class="setup-input" placeholder="http://your-paperless-instance:8000" required value="<%= config.PAPERLESS_API_URL || '' %>">
                        </div>
                        <div class="space-y-2">
                            <label for="paperlessUsername" class="text-sm font-medium">Paperless username</label>
                            <input id="paperlessUsername" name="paperlessUsername" type="text" class="setup-input" required value="<%= config.PAPERLESS_USERNAME || '' %>">
                        </div>
                        <div class="space-y-2">
                            <label for="paperlessToken" class="text-sm font-medium">API token</label>
                            <input id="paperlessToken" name="paperlessToken" type="password" class="setup-input" required value="<%= config.PAPERLESS_API_TOKEN || '' %>">
                        </div>
                    </div>

                    <div class="mt-4 flex flex-wrap items-center gap-3">
                        <button type="button" id="testPaperlessBtn" class="setup-btn setup-btn-secondary">
                            <i class="fas fa-plug-circle-check"></i>
                            Test Paperless connection
                        </button>
                        <span id="paperlessTestState" class="setup-pill">Not tested</span>
                    </div>
                </section>

                <section class="setup-step" data-step-index="3" data-step-title="Paperless metadata">
                    <h3 class="setup-section-title"><i class="fas fa-database"></i> Paperless metadata</h3>
                    <p class="setup-section-help">Load document statistics and choose tagging rules.</p>

                    <div class="mt-4 flex flex-wrap items-center gap-3">
                        <button type="button" id="fetchMetadataBtn" class="setup-btn setup-btn-secondary">
                            <i class="fas fa-arrows-rotate"></i>
                            Load metadata from Paperless
                        </button>
                        <span id="metadataLoadState" class="setup-pill">Not loaded</span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-4">
                        <article class="setup-stat-card">
                            <p class="setup-stat-label">Documents</p>
                            <p id="documentsCount" class="setup-stat-value">-</p>
                        </article>
                        <article class="setup-stat-card">
                            <p class="setup-stat-label">Correspondents</p>
                            <p id="correspondentsCount" class="setup-stat-value">-</p>
                        </article>
                        <article class="setup-stat-card">
                            <p class="setup-stat-label">Tags</p>
                            <p id="tagsCount" class="setup-stat-value">-</p>
                        </article>
                    </div>

                    <div class="space-y-4 mt-5">
                        <label class="flex items-start gap-3">
                            <input id="scanAllDocuments" type="checkbox" class="mt-1">
                            <span>
                                <strong>Always scan all documents</strong>
                                <span class="block setup-hint">If enabled, no include-tag filter is used.</span>
                            </span>
                        </label>

                        <div class="space-y-2">
                            <label for="includeTag" class="text-sm font-medium">Tag used to select documents for processing</label>
                            <input id="includeTag" type="text" class="setup-input" list="paperlessTagsDatalist" placeholder="Select or type a tag">
                        </div>

                        <div class="space-y-2">
                            <label for="excludeTagInput" class="text-sm font-medium">Excluded tags</label>
                            <div class="flex gap-2">
                                <input id="excludeTagInput" type="text" class="setup-input flex-1" list="paperlessTagsDatalist" placeholder="Select a tag to exclude">
                                <button type="button" id="addExcludeTagBtn" class="setup-btn setup-btn-secondary">Add</button>
                            </div>
                            <div id="excludeTagsContainer" class="setup-chip-container"></div>
                        </div>

                        <div class="space-y-2">
                            <label for="processedTag" class="text-sm font-medium">Tag applied after Paperless-AI finishes</label>
                            <div class="flex gap-2">
                                <input id="processedTag" type="text" class="setup-input flex-1" list="paperlessTagsDatalist" placeholder="e.g. ai-processed" value="<%= config.AI_PROCESSED_TAG_NAME || 'ai-processed' %>">
                                <button type="button" id="excludeProcessedTagBtn" class="setup-btn setup-btn-secondary">Exclude this tag</button>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <label for="automaticScanEnabled" class="text-sm font-medium">Automatic scanning</label>
                                <select id="automaticScanEnabled" class="setup-input">
                                    <option value="yes" <%= config.DISABLE_AUTOMATIC_PROCESSING === 'yes' ? '' : 'selected' %>>Yes</option>
                                    <option value="no" <%= config.DISABLE_AUTOMATIC_PROCESSING === 'yes' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label for="scanInterval" class="text-sm font-medium">Scan interval (cron)</label>
                                <input id="scanInterval" type="text" class="setup-input" value="<%= config.SCAN_INTERVAL || (defaults && defaults.scanInterval) || '*/30 * * * *' %>">
                            </div>
                        </div>
                    </div>

                    <datalist id="paperlessTagsDatalist"></datalist>
                </section>

                <section class="setup-step" data-step-index="4" data-step-title="AI credentials">
                    <h3 class="setup-section-title"><i class="fas fa-robot"></i> AI access credentials</h3>
                    <p class="setup-section-help">Select a predefined provider preset and test credentials.</p>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                        <div class="space-y-2 md:col-span-2">
                            <label for="aiPreset" class="text-sm font-medium">Provider preset</label>
                            <select id="aiPreset" class="setup-input"></select>
                            <p id="aiPresetHint" class="setup-hint"></p>
                        </div>
                        <div class="space-y-2">
                            <label for="aiProvider" class="text-sm font-medium">Provider type</label>
                            <input id="aiProvider" class="setup-input" readonly>
                        </div>
                        <div class="space-y-2">
                            <label for="aiModel" class="text-sm font-medium">Model</label>
                            <div class="flex flex-col sm:flex-row gap-2">
                                <select id="aiModel" class="setup-input" required>
                                    <option value="">Select a model</option>
                                </select>
                                <button type="button" id="fetchAiModelsBtn" class="setup-btn setup-btn-warning whitespace-nowrap flex items-center gap-2">
                                    <i class="fas fa-list"></i>
                                    <span>Fetch models</span>
                                </button>
                            </div>
                        </div>
                        <div class="space-y-2 md:col-span-2">
                            <label for="aiApiUrl" class="text-sm font-medium">API URL</label>
                            <input id="aiApiUrl" type="text" class="setup-input" required>
                        </div>
                        <div class="space-y-2 md:col-span-2">
                            <label for="aiToken" class="text-sm font-medium">API token</label>
                            <input id="aiToken" type="password" class="setup-input" placeholder="Enter token if required">
                            <p class="setup-hint">For custom endpoints, this field can stay empty if the API does not require authentication.</p>
                        </div>
                    </div>

                    <div class="mt-4 flex flex-wrap items-center gap-3">
                        <button type="button" id="testAiBtn" class="setup-btn setup-btn-secondary">
                            <i class="fas fa-flask"></i>
                            Test AI connection
                        </button>
                        <span id="aiTestState" class="setup-pill">Not tested</span>
                    </div>
                </section>

                <section class="setup-step" data-step-index="5" data-step-title="OCR fallback">
                    <h3 class="setup-section-title"><i class="fas fa-file-lines"></i> OCR fallback</h3>
                    <p class="setup-section-help">Configure OCR fallback for documents where AI extraction needs OCR assistance.</p>

                    <div class="space-y-2 mt-4">
                        <label for="mistralOcrEnabled" class="text-sm font-medium">Enable OCR</label>
                        <select id="mistralOcrEnabled" class="setup-input">
                            <option value="no" <%= config.MISTRAL_OCR_ENABLED === 'yes' ? '' : 'selected' %>>No</option>
                            <option value="yes" <%= config.MISTRAL_OCR_ENABLED === 'yes' ? 'selected' : '' %>>Yes</option>
                        </select>
                    </div>

                    <div id="mistralFields" class="hidden space-y-4 mt-4">
                        <div class="space-y-2">
                            <label for="ocrProvider" class="text-sm font-medium">OCR provider</label>
                            <select id="ocrProvider" class="setup-input">
                                <option value="mistral" <%= (config.OCR_PROVIDER || 'mistral') === 'mistral' ? 'selected' : '' %>>Mistral OCR API</option>
                                <option value="custom" <%= ((config.OCR_PROVIDER || 'mistral') === 'custom' || (config.OCR_PROVIDER || 'mistral') === 'ollama') ? 'selected' : '' %>>Custom (Ollama, LM Studio, local models)</option>
                            </select>
                        </div>
                        <div id="ocrApiUrlContainer" class="space-y-2">
                            <label for="ocrApiUrl" class="text-sm font-medium">OCR API URL (optional override)</label>
                            <input id="ocrApiUrl" type="text" class="setup-input" value="<%= config.OCR_API_URL || '' %>" placeholder="Leave empty to use provider default URL">
                            <p class="setup-hint">For custom provider, set URL to your local endpoint (e.g. Ollama or LM Studio /v1).</p>
                        </div>
                        <div id="ocrApiKeyContainer" class="space-y-2">
                            <label for="ocrApiKey" class="text-sm font-medium">OCR API key</label>
                            <input id="ocrApiKey" type="password" class="setup-input" placeholder="Optional for local/custom OCR, required for Mistral">
                        </div>
                        <div class="space-y-2">
                            <label for="mistralOcrModel" class="text-sm font-medium">OCR model</label>
                            <div class="flex flex-col sm:flex-row gap-2">
                                <select id="mistralOcrModel" class="setup-input">
                                    <option value="<%= config.MISTRAL_OCR_MODEL || 'mistral-ocr-latest' %>" selected><%= config.MISTRAL_OCR_MODEL || 'mistral-ocr-latest' %></option>
                                </select>
                                <button type="button" id="fetchOcrModelsBtn" class="setup-btn setup-btn-warning whitespace-nowrap flex items-center gap-2">
                                    <i class="fas fa-list"></i>
                                    <span>Fetch OCR models</span>
                                </button>
                            </div>
                        </div>
                        <div class="flex flex-wrap items-center gap-3">
                            <button type="button" id="testOcrBtn" class="setup-btn setup-btn-warning flex items-center gap-2">
                                <i class="fas fa-flask"></i>
                                <span>Test OCR connection</span>
                            </button>
                            <span id="ocrTestState" class="setup-pill">Not tested</span>
                        </div>
                    </div>
                </section>

                <section class="setup-step" data-step-index="6" data-step-title="Review and finish">
                    <h3 class="setup-section-title"><i class="fas fa-clipboard-check"></i> Review and finish</h3>
                    <p class="setup-section-help">Review generated environment keys, copy if needed, then finalize setup.</p>

                    <div class="space-y-2 mt-4">
                        <label for="envPreview" class="text-sm font-medium">For docker compose copy</label>
                        <textarea id="envPreview" class="setup-input setup-textarea" rows="12" readonly></textarea>
                    </div>

                    <div class="flex flex-wrap gap-3 mt-4">
                        <button type="button" id="copyEnvPreviewBtn" class="setup-btn setup-btn-secondary">
                            <i class="fas fa-copy"></i>
                            Copy to clipboard
                        </button>
                        <button type="button" id="finalizeSetupBtn" class="setup-btn setup-btn-primary">
                            <i class="fas fa-check"></i>
                            Save and restart container
                        </button>
                    </div>
                </section>

                <footer class="setup-footer pt-4">
                    <button type="button" id="prevStepBtn" class="setup-btn setup-btn-secondary" disabled>
                        <i class="fas fa-arrow-left"></i>
                        Previous
                    </button>
                    <button type="button" id="nextStepBtn" class="setup-btn setup-btn-primary">
                        Next
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </footer>
            </form>
        </section>
    </main>

    <script>
        window.__SETUP_BOOTSTRAP__ = <%- JSON.stringify({
            config: config || {},
            defaults: defaults || {},
            aiProviderPresets: Array.isArray(aiProviderPresets) ? aiProviderPresets : []
        }).replace(/</g, '\\u003c') %>;
    </script>
    <%- include('partials/scripts/login-scripts') %>
    <script src="/js/setup.js" defer></script>
</body>
</html>
